{
  "expo": {
    "name": "Capitillian",
    "slug": "capitillian",
    "version": "1.7.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.capitillian.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.capitillian.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "kk-11-xe"
        }
      ],
      "expo-asset"
    ],
    "scheme": "capitillian",
    "extra": {
      "eas": {
        "projectId": "d0e1cc86-17e0-4959-8457-7579c334bc1d"
      }
    },
    "owner": "kk-11"
  }
}
